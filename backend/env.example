SECRET_KEY=replace-with-long-random-string
DATABASE_URL=sqlite:///./inkmind.db

DEFAULT_LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SEND_TEMPERATURE=true
OPENAI_TIMEOUT=120

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 通义千问（阿里云 DashScope，OpenAI 兼容模式）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-max
QWEN_SEND_TEMPERATURE=true
QWEN_TIMEOUT=120

# DeepSeek 官方 API（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_SEND_TEMPERATURE=true
DEEPSEEK_TIMEOUT=120

# MiniMax（OpenAI 兼容，DEFAULT_LLM_PROVIDER=minimax）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_SEND_TEMPERATURE=true
MINIMAX_TIMEOUT=120

# Kimi / 月之暗面 Moonshot（OpenAI 兼容，DEFAULT_LLM_PROVIDER=kimi）
# 也可只设 KIMI_API_KEY（与 MOONSHOT_API_KEY 二选一）
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=moonshot-v1-32k
MOONSHOT_SEND_TEMPERATURE=true
MOONSHOT_TIMEOUT=120

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenTelemetry：AI 路径手动 Span + FastAPI/HTTPX 自动插桩。未设置 OTLP 时 Span 打印到控制台。
# OTEL_ENABLED=1
# OTEL_SERVICE_NAME=inkmind-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
