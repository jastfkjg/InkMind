# ==========================================
# InkMind 开发环境配置
# ==========================================
# 复制此文件为 .env 后修改相应配置
# 注意：.env 文件不应提交到 git 仓库

# ==========================================
# 前端配置
# ==========================================
# 前端开发服务器端口
VITE_FRONTEND_PORT=5173

# ==========================================
# 后端配置
# ==========================================
# 后端地址（用于前端代理）
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8000

# ==========================================
# 后端启动命令示例
# ==========================================
# 如果 8000 端口被占用，使用其他端口启动后端：
# cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload
#
# 同时修改此处的 VITE_BACKEND_PORT=8001
# ==========================================
